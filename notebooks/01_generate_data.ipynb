# Генерация синтетических данных тренировок
import pandas as pd
import numpy as np
from faker import Faker
from datetime import datetime, timedelta

fake = Faker()
np.random.seed(42)

# Генерация дат (3 месяца, 3 тренировки в неделю)
start_date = datetime(2024, 1, 1)
dates = []
current = start_date
while current < datetime(2024, 4, 1):
    if current.weekday() in [0, 2, 5]:  # ПН, СР, СБ
        dates.append(current)
    current += timedelta(days=1)

# Генерация прогрессирующих дистанций
base_distance = 3.0
distances = []
for i, d in enumerate(dates):
    progress = i * 0.1
    noise = np.random.normal(0, 0.3)
    dist = max(2.0, base_distance + progress + noise)
    distances.append(round(dist, 2))

# Генерация времени (темп ~6 мин/км)
durations = [round(d * 6 + np.random.normal(0, 2), 1) for d in distances]

# Создание DataFrame
df = pd.DataFrame({
    'date': dates,
    'distance_km': distances,
    'duration_min': durations,
    'avg_pace': [round(dur/dist, 2) for dur, dist in zip(durations, distances)],
    'notes': ['Тренировка ' + fake.word() for _ in dates]
})

# Сохранение
df.to_csv('../data/training_data.csv', index=False)
print(f"Сгенерировано {len(df)} записей")
df.head()
